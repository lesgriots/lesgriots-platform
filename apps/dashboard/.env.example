# Copier ce fichier en .env.local et remplir les vraies valeurs.
# .env.local est gitignored — il ne sera JAMAIS commité.

# Mot de passe d'accès admin (login interne)
ADMIN_PASSWORD=

# Port d'écoute (par défaut 3000)
PORT=3000

